<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · Freight Dashboard">
      {assigns[:page_title] || "Freight Dashboard"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <style>
      :root {
        --bg: #1a1a2e;
        --surface: #16213e;
        --surface-alt: #0f3460;
        --text: #e4e4e4;
        --text-muted: #a0a0b0;
        --accent: #e94560;
        --accent-alt: #533483;
        --green: #4ecca3;
        --yellow: #f0a500;
        --red: #e94560;
        --border: #2a2a4a;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        line-height: 1.6;
        min-height: 100vh;
      }

      .dashboard { max-width: 1000px; margin: 0 auto; padding: 2rem 1rem; }
      .dashboard-header h1 { font-size: 2rem; margin-bottom: 0.25rem; }
      .subtitle { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem; }

      .widgets { display: grid; gap: 1.5rem; margin-top: 1.5rem; }
      .widget {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.5rem;
      }
      .widget h2 { margin-bottom: 1rem; font-size: 1.2rem; }

      .flag-manager {
        background: var(--surface-alt);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
      }
      .flag-manager h3 { margin-bottom: 0.75rem; }
      .flag-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
      }
      .flag-row:last-of-type { border-bottom: none; }
      .flag-info { display: flex; flex-direction: column; gap: 0.15rem; font-size: 0.9rem; }
      .flag-info code {
        background: var(--bg);
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        font-size: 0.8rem;
        color: var(--accent);
      }
      .flag-row button {
        background: var(--accent);
        color: white;
        border: none;
        border-radius: 4px;
        padding: 0.4rem 0.8rem;
        cursor: pointer;
        font-size: 0.85rem;
      }
      .flag-row button:hover { opacity: 0.9; }
      .flag-note {
        margin-top: 0.75rem;
        font-size: 0.8rem;
        color: var(--text-muted);
      }

      .shipment-table { width: 100%; border-collapse: collapse; }
      .shipment-table th, .shipment-table td {
        padding: 0.6rem 0.8rem; text-align: left;
        border-bottom: 1px solid var(--border);
      }
      .shipment-table th {
        background: var(--surface-alt);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .fleet-list { list-style: none; }
      .fleet-list li { padding: 0.5rem 0; border-bottom: 1px solid var(--border); }

      .shipment-card {
        display: flex; align-items: center; gap: 1rem;
        padding: 0.75rem; border-bottom: 1px solid var(--border);
      }
      .truck-icon { font-size: 1.4rem; }
      .shipment-info { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; }
      .progress-bar {
        width: 120px; height: 8px; background: var(--bg);
        border-radius: 4px; overflow: hidden;
      }
      .progress-fill { height: 100%; border-radius: 4px; }
      .progress-in_transit { width: 50%; background: var(--yellow); }
      .progress-delivered { width: 100%; background: var(--green); }
      .progress-pending { width: 10%; background: var(--text-muted); }
      .status-badge {
        font-size: 0.8rem; padding: 0.15rem 0.5rem;
        border-radius: 3px; background: var(--surface-alt);
      }

      .fleet-cards { display: grid; gap: 0.75rem; }
      .status-card {
        display: flex; align-items: center; gap: 1rem;
        padding: 0.75rem; border: 1px solid var(--border);
        border-radius: 6px; background: var(--surface-alt);
      }
      .vehicle-icon { font-size: 1.4rem; }
      .vehicle-info { flex: 1; display: flex; flex-direction: column; gap: 0.15rem; }
      .status-available { background: var(--green); color: #000; }
      .status-on-route { background: var(--yellow); color: #000; }
      .status-maintenance { background: var(--red); }
      .location-badge { font-size: 0.8rem; color: var(--text-muted); }

      .dashboard-footer {
        margin-top: 2.5rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        text-align: center;
        font-size: 0.8rem;
        color: var(--text-muted);
      }
      .dashboard-footer a {
        color: var(--accent);
        text-decoration: none;
      }
      .dashboard-footer a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
